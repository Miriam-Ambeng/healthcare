PORT=5000
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/healthcare_appointments
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=30d
REMINDER_INTERVAL_MS=60000

APP_NAME=Automated Health Care Appointment System
APP_EMAIL=no-reply@example.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_SMS_FROM=+10000000000
TWILIO_WHATSAPP_FROM=whatsapp:+10000000000
